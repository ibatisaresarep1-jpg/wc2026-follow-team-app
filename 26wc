      x: {
        ticks: { color: "#9ca3af", font: { size: 10 } },
        grid: { display: false }
      },
      y: {
        min: 0,
        max: 100,
        ticks: { color: "#9ca3af" },
        grid: { color: "#1f2937" }
      }
    }
  }
});

// --- INITIAL STATE ---
const initial = getFilteredMatches()[0];
if (initial) {
  renderDetails(initial);
  updateLiveActivity(initial);
} else {
  renderDetails(null);
  updateLiveActivity(null);
}
applyTheme("Netherlands");

// --- FILTER CHANGE ---
teamFilter.addEventListener("change", () => {
  chart.data = buildChartData();
  chart.update();
  const first = getFilteredMatches()[0];
  renderDetails(first || null);
  updateLiveActivity(first || null);
});

stageFilter.addEventListener("change", () => {
  chart.data = buildChartData();
  chart.update();
  const first = getFilteredMatches()[0];
  renderDetails(first || null);
  updateLiveActivity(first || null);
});

// --- NEXT MATCH SCROLL ---
function scrollToNextFollowedMatch() {
  const follow = followTeam.value;
  const data = getFilteredMatches();

  const next = data.find(m =>
    m.homeTeam === follow || m.awayTeam === follow
  );

  if (!next) return;

  document.getElementById("chartCard")
    .scrollIntoView({ behavior: "smooth" });

  renderDetails(next);
  updateLiveActivity(next);

  const details = document.getElementById("details");
  details.classList.add("fade-slide");
  setTimeout(() => details.classList.remove("fade-slide"), 400);
}

document.getElementById("nextMatchBtn").addEventListener("click", () => {
  scrollToNextFollowedMatch();
});

// --- FOLLOW TEAM CHANGE ---
followTeam.addEventListener("change", () => {
  applyTheme(followTeam.value);
  chart.data = buildChartData();
  chart.update();
  followChart.data = buildFollowChartData();
  followChart.update();
  scrollToNextFollowedMatch();
  document.getElementById("followChartCard")
    .scrollIntoView({ behavior: "smooth" });
});

// --- BOTTOM TABS + SWIPE ---
const bottomTabs = document.querySelectorAll("#bottomTabs button");

bottomTabs.forEach(btn => {
  btn.addEventListener("click", () => {
    bottomTabs.forEach(b => {
      b.classList.remove("active");
      b.style.color = "#e5e7eb";
    });
    btn.classList.add("active");
    const id = teamIdentity[followTeam.value] || { color: "#ff7f00" };
    btn.style.color = id.color;

    const targetId = btn.dataset.target;
    const targetEl = document.getElementById(targetId);
    if (targetEl) {
      targetEl.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    if (navigator.vibrate) {
      navigator.vibrate(10);
    }
  });
});

let touchStartX = 0;

document.addEventListener("touchstart", e => {
  touchStartX = e.changedTouches[0].screenX;
});

document.addEventListener("touchend", e => {
  const diff = e.changedTouches[0].screenX - touchStartX;
  if (Math.abs(diff) < 80) return;

  const order = ["spotlightCard", "filtersCard", "chartCard", "followChartCard", "details"];
  const current = order.indexOf(
    document.querySelector("#bottomTabs button.active").dataset.target
  );

  let next = current + (diff < 0 ? 1 : -1);
  if (next < 0 || next >= order.length) return;

  document.querySelector(`#bottomTabs button[data-target="${order[next]}"]`).click();
});

// --- PWA SERVICE WORKER REG ---
if ("serviceWorker" in navigator) {
  window.addEventListener("load", () => {
    navigator.serviceWorker.register("sw.js");
  }
const CACHE_NAME = "wc2026-pwa-v1";
const ASSETS = [
  "./",
  "./index.html",
  "./style.css",
  "./app.js",
  "./manifest.webmanifest"
];

self.addEventListener("install", event => {
  event.waitUntil(
    caches.open(CACHE_NAME).then(cache => cache.addAll(ASSETS))
  );
});

self.addEventListener("activate", event => {
  event.waitUntil(
    caches.keys().then(keys =>
      Promise.all(
        keys.filter(k => k !== CACHE_NAME).map(k => caches.delete(k))
      )
    )
  );
});

self.addEventListener("fetch", event => {
  event.respondWith(
    caches.match(event.request).then(resp => resp || fetch(event.request))
  );
});
