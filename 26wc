// --- MATCH GENERATION ---
let matchIdCounter = 1;
const groupMatches = [];

function generateGroupMatches() {
  const dates = [];
  let baseDate = new Date("2026-06-11");
  for (let i = 0; i < 20; i++) {
    dates.push(new Date(baseDate));
    baseDate.setDate(baseDate.getDate() + 1);
  }

  let dateIndex = 0;
  let venueIndex = 0;

  Object.entries(groups).forEach(([groupName, teams]) => {
    for (let i = 0; i < teams.length; i++) {
      for (let j = i + 1; j < teams.length; j++) {
        const homeTeam = teams[i];
        const awayTeam = teams[j];
        const dateObj = dates[dateIndex % dates.length];
        const dateStr = dateObj.toISOString().slice(0, 10);
        const city = cities[venueIndex % cities.length];
        const stadium = stadiums[venueIndex % stadiums.length];

        groupMatches.push({
          matchId: matchIdCounter++,
          stage: "Group",
          group: groupName,
          date: dateStr,
          city,
          stadium,
          homeTeam,
          awayTeam,
          homeRating: teamRatings[homeTeam] || 3,
          awayRating: teamRatings[awayTeam] || 3
        });

        dateIndex++;
        venueIndex++;
      }
    }
  });
}

generateGroupMatches();

const knockoutMatches = [];
function addKnockout(stage, count) {
  for (let i = 1; i <= count; i++) {
    const city = cities[(matchIdCounter + i) % cities.length];
    const stadium = stadiums[(matchIdCounter + i) % stadiums.length];
    knockoutMatches.push({
      matchId: matchIdCounter++,
      stage,
      group: "",
      date: "2026-07-" + String(1 + Math.floor((matchIdCounter - 73) / 2)).padStart(2, "0"),
      city,
      stadium,
      homeTeam: `${stage} Match ${i}A`,
      awayTeam: `${stage} Match ${i}B`,
      homeRating: 4,
      awayRating: 4
    });
  }
}

addKnockout("Round of 32", 16);
addKnockout("Round of 16", 8);
addKnockout("Quarterfinal", 4);
addKnockout("Semifinal", 2);
addKnockout("Final", 1);
addKnockout("Third place", 1);

const matches = [...groupMatches, ...knockoutMatches];

// --- PREDICTION MODEL ---
function computeProbabilities(homeRating, awayRating) {
  const delta = homeRating - awayRating;
  const Sh = 1 / (1 + Math.pow(10, -delta / 4));
  const draw = 0.25;
  return {
    home: Sh * (1 - draw),
    draw: draw,
    away: (1 - Sh) * (1 - draw)
  };
}

matches.forEach(m => {
  const p = computeProbabilities(m.homeRating, m.awayRating);
  m.homeWinProb = p.home;
  m.drawProb = p.draw;
  m.awayWinProb = p.away;
});

// --- DOM ELEMENTS ---
const teamFilter = document.getElementById("teamFilter");
const stageFilter = document.getElementById("stageFilter");
const followTeam = document.getElementById("followTeam");
const detailsContent = document.getElementById("detailsContent");
const liveMatchText = document.getElementById("liveMatchText");

// --- TEAM DROPDOWNS ---
const teamSet = new Set();
matches.forEach(m => {
  teamSet.add(m.homeTeam);
  teamSet.add(m.awayTeam);
});

[...teamSet].sort().forEach(team => {
  const opt1 = document.createElement("option");
  opt1.value = team;
  opt1.textContent = team;
  teamFilter.appendChild(opt1);

  const opt2 = document.createElement("option");
  opt2.value = team;
  opt2.textContent = team;
  followTeam.appendChild(opt2);
});

followTeam.value = "Netherlands";

// --- FILTERING ---
function getFilteredMatches() {
  const team = teamFilter.value;
  const stage = stageFilter.value;

  return matches.filter(m => {
    const teamMatch = !team || m.homeTeam === team || m.awayTeam === team;
    const stageMatch = !stage || m.stage === stage;
    return teamMatch && stageMatch;
  });
}

// --- MAIN CHART DATA ---
function buildChartData() {
  const data = getFilteredMatches();
  const follow = followTeam.value;
  const id = teamIdentity[follow] || { color: "#22c55e" };

  return {
    labels: data.map(m => `#${m.matchId} ${m.homeTeam} vs ${m.awayTeam}`),
    datasets: [
      {
        label: "Home Win %",
        data: data.map(m => m.homeWinProb * 100),
        backgroundColor: data.map(m =>
          m.homeTeam === follow || m.awayTeam === follow
            ? id.color
            : "rgba(34, 197, 94, 0.85)"
        ),
        stack: "prob"
      },
      {
        label: "Draw %",
        data: data.map(m => m.drawProb * 100),
        backgroundColor: "rgba(148, 163, 184, 0.85)",
        stack: "prob"
      },
      {
        label: "Away Win %",
        data: data.map(m => m.awayWinProb * 100),
        backgroundColor: data.map(m =>
          m.homeTeam === follow || m.awayTeam === follow
            ? id.color + "55"
            : "rgba(239, 68, 68, 0.85)"
        ),
        stack: "prob"
      }
    ]
  };
}

// --- FOLLOW TEAM ONLY CHART DATA ---
function buildFollowChartData() {
  const follow = followTeam.value;
  const id = teamIdentity[follow] || { color: "#ff7f00" };

  const data = matches.filter(
    m => m.homeTeam === follow || m.awayTeam === follow
  );

  return {
    labels: data.map(m => `#${m.matchId} ${m.homeTeam} vs ${m.awayTeam}`),
    datasets: [
      {
        label: `${follow} Win %`,
        data: data.map(m =>
          m.homeTeam === follow
            ? m.homeWinProb * 100
            : m.awayWinProb * 100
        ),
        backgroundColor: id.color,
        borderColor: id.color,
        borderWidth: 1
      },
      {
        label: "Draw %",
        data: data.map(m => m.drawProb * 100),
        backgroundColor: id.color + "55",
        borderColor: id.color + "55",
        borderWidth: 1
      }
    ]
  };
}

// --- DETAILS PANEL ---
function renderDetails(match) {
  if (!match) {
    detailsContent.innerHTML = "<p>No match selected.</p>";
    return;
  }

  const follow = followTeam.value;
  const isFollowed =
    match.homeTeam === follow || match.awayTeam === follow;
  const id = teamIdentity[follow] || { color: "#ff7f00" };

  const followTag = isFollowed
    ? `<p style="color:${id.color};font-weight:600;">This is a ${follow} match.</p>`
    : "";

  detailsContent.innerHTML = `
    <p><span class="label">Match:</span> #${match.matchId} – ${match.homeTeam} vs ${match.awayTeam}</p>
    <p><span class="label">Stage:</span> ${match.stage}${match.group ? " (Group " + match.group + ")" : ""}</p>
    <p><span class="label">Date:</span> ${match.date}</p>
    <p><span class="label">City / Stadium:</span> ${match.city} – ${match.stadium}</p>
    <p><span class="label">Ratings:</span> ${match.homeTeam} ${match.homeRating} ★, ${match.awayTeam} ${match.awayRating} ★</p>
    ${followTag}
    <p><span class="label">Predicted probabilities:</span></p>
    <ul>
      <li>${match.homeTeam} win: ${(match.homeWinProb * 100).toFixed(1)}%</li>
      <li>Draw: ${(match.drawProb * 100).toFixed(1)}%</li>
      <li>${match.awayTeam} win: ${(match.awayWinProb * 100).toFixed(1)}%</li>
    </ul>
  `;
}

// --- DYNAMIC ISLAND ---
function updateLiveActivity(match) {
  const follow = followTeam.value;
  const id = teamIdentity[follow] || { color: "#ff7f00", secondary: "#000" };

  document.documentElement.style.setProperty("--accent", id.color);
  document.documentElement.style.setProperty("--accent-secondary", id.secondary);
  document.getElementById("liveActivity").style.borderColor = id.color;

  if (!match) {
    liveMatchText.textContent = "No match selected";
    return;
  }

  const isFollowed =
    match.homeTeam === follow || match.awayTeam === follow;

  liveMatchText.textContent =
    `${isFollowed ? "⭐ " : ""}${match.homeTeam} vs ${match.awayTeam} • ${match.date}`;
}

// --- THEME ENGINE ---
function applyTheme(team) {
  const id = teamIdentity[team] || {
    color: "#ff7f00",
    secondary: "#000",
    nickname: team,
    legends: [],
    stars: []
  };

  document.body.classList.add("theme-transition");

  document.body.style.background = wallpapers[team] || "#000";

  document.documentElement.style.setProperty("--accent", id.color);
  document.documentElement.style.setProperty("--accent-secondary", id.secondary);

  document.getElementById("spotlightTitle").textContent = `${team} Spotlight`;
  document.getElementById("spotlightNickname").textContent = id.nickname || team;
  document.getElementById("spotlightLegends").textContent = id.legends.join(", ") || "—";
  document.getElementById("spotlightStars").textContent = id.stars.join(", ") || "—";

  const badge = document.getElementById("spotlightBadge");
  badge.style.borderColor = id.color;
  badge.style.background = id.color + "22";
  badge.style.color = id.color;
  badge.querySelector(".nl-dot").style.background = id.color;

  document.querySelectorAll("#bottomTabs button.active")
    .forEach(btn => btn.style.color = id.color);

  ["spotlightCard", "chartCard", "followChartCard", "details"].forEach(idEl => {
    const el = document.getElementById(idEl);
    el.classList.add("fade-slide");
    setTimeout(() => el.classList.remove("fade-slide"), 400);
  });

  followChart.data = buildFollowChartData();
  followChart.update();
}

// --- MAIN CHART INIT ---
const ctx = document.getElementById("wcChart").getContext("2d");
let chart = new Chart(ctx, {
  type: "bar",
  data: buildChartData(),
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      tooltip: {
        callbacks: {
          title: (items) => {
            const data = getFilteredMatches();
            const idx = items[0].dataIndex;
            const m = data[idx];
            return `Match ${m.matchId}: ${m.homeTeam} vs ${m.awayTeam}`;
          },
          afterBody: (items) => {
            const data = getFilteredMatches();
            const idx = items[0].dataIndex;
            const m = data[idx];
            return [
              `Stage: ${m.stage}${m.group ? " (Group " + m.group + ")" : ""}`,
              `Date: ${m.date}`,
              `City: ${m.city}`,
              `Stadium: ${m.stadium}`
            ];
          }
        }
      },
      legend: {
        labels: {
          color: "#e5e7eb",
          font: { size: 11 }
        }
      }
    },
    scales: {
      x: {
        stacked: true,
        ticks: {
          autoSkip: false,
          maxRotation: 60,
          minRotation: 30,
          color: "#9ca3af",
          font: { size: 9 }
        },
        grid: { display: false }
      },
      y: {
        stacked: true,
        title: { display: true, text: "Probability (%)", color: "#e5e7eb" },
        min: 0,
        max: 100,
        ticks: { color: "#9ca3af" },
        grid: { color: "#1f2937" }
      }
    },
    onClick: (evt, elements) => {
      if (!elements.length) return;
      const index = elements[0].index;
      const data = getFilteredMatches();
      const match = data[index];
      renderDetails(match);
      updateLiveActivity(match);
    }
  }
});

// --- FOLLOW CHART INIT ---
const followCtx = document.getElementById("followChart").getContext("2d");
let followChart = new Chart(followCtx, {
  type: "bar",
  data: buildFollowChartData(),
  options: {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: {
        labels: {
          color: "#e5e7eb",
          font: { size: 11 }
        }
      }
    },
