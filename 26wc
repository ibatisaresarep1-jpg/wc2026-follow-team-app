<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>World Cup 2026 – Follow Your Team</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link rel="manifest" href="manifest.webmanifest">
  <meta name="theme-color" content="#000000">
  <link rel="apple-touch-icon" href="icons/icon-192.png">

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
  <h1 id="appTitle">World Cup 2026</h1>
  <p id="appSubtitle">Follow your team with live-style predictions and an iOS feel.</p>
</header>

<div id="liveActivity">
  <span id="liveMatchText">No match selected</span>
</div>

<main>
  <section class="card" id="spotlightCard">
    <h2 id="spotlightTitle">Team Spotlight</h2>

    <label class="follow-label">
      <span>Follow a team:</span>
      <select id="followTeam"></select>
    </label>

    <p class="nl-badge" id="spotlightBadge">
      <span class="nl-dot"></span>
      <span id="spotlightNickname">Pick a team to start</span>
    </p>

    <p><span class="label">Legends:</span> <span id="spotlightLegends">—</span></p>
    <p><span class="label">Stars:</span> <span id="spotlightStars">—</span></p>

    <button id="nextMatchBtn">Next Match</button>
  </section>

  <section class="card" id="filtersCard">
    <h2>Filters</h2>
    <p>Focus on a specific team or stage.</p>
    <div class="filters">
      <label>
        Filter by team:
        <select id="teamFilter">
          <option value="">All teams</option>
        </select>
      </label>

      <label>
        Filter by stage:
        <select id="stageFilter">
          <option value="">All stages</option>
          <option value="Group">Group Stage</option>
          <option value="Round of 32">Round of 32</option>
          <option value="Round of 16">Round of 16</option>
          <option value="Quarterfinal">Quarterfinal</option>
          <option value="Semifinal">Semifinal</option>
          <option value="Final">Final</option>
          <option value="Third place">Third place</option>
        </select>
      </label>
    </div>
  </section>

  <section class="card" id="chartCard">
    <h2>Probability Chart</h2>
    <p>Stacked bars show home win, draw, and away win probabilities.</p>
    <div class="chart-container">
      <canvas id="wcChart"></canvas>
    </div>
  </section>

  <section class="card" id="followChartCard">
    <h2 id="followChartTitle">Followed Team Matches</h2>
    <p>Only matches involving your followed team appear here.</p>
    <div class="chart-container">
      <canvas id="followChart"></canvas>
    </div>
  </section>

  <section class="card" id="details">
    <h3>Match details</h3>
    <p>Select a bar in the chart to see full info here.</p>
    <div id="detailsContent"></div>
  </section>
</main>

<div id="bottomTabs">
  <button data-target="spotlightCard">Follow</button>
  <button data-target="filtersCard">Filters</button>
  <button data-target="chartCard" class="active">Chart</button>
  <button data-target="followChartCard">Follow Chart</button>
  <button data-target="details">Details</button>
</div>

<script src="app.js"></script>
</body>
</html>

:root {
  --accent: #ff7f00;
  --accent-secondary: #1a1a1a;
}

* {
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  margin: 0;
  color: #f5f5f5;
  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  transition: background 0.4s ease;
}

header {
  padding: 14px 18px 8px;
  background: rgba(10, 10, 10, 0.9);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid #1f2937;
  position: sticky;
  top: 0;
  z-index: 900;
}

header h1 {
  margin: 0;
  font-size: 20px;
  font-weight: 700;
  color: var(--accent);
}

header p {
  margin: 4px 0 0;
  font-size: 13px;
  color: #9ca3af;
}

main {
  padding: 12px 16px 80px;
}

.card {
  background: rgba(15, 23, 42, 0.96);
  border-radius: 18px;
  border: 1px solid #1f2937;
  padding: 14px 16px;
  margin-bottom: 12px;
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.7);
}

.card h2 {
  margin: 0 0 8px;
  font-size: 16px;
  font-weight: 600;
}

.card p {
  margin: 4px 0 10px;
  font-size: 13px;
  color: #9ca3af;
}

.label {
  font-weight: 600;
}

.follow-label {
  display: block;
  margin-top: 10px;
  font-size: 13px;
  color: #9ca3af;
}

.follow-label span {
  display: block;
  margin-bottom: 4px;
}

.follow-label select {
  width: 100%;
}

select {
  padding: 8px 10px;
  border-radius: 12px;
  border: 1px solid #374151;
  background: #020617;
  color: #f5f5f5;
  font-size: 13px;
}

.filters {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.filters label {
  font-size: 13px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.chart-container {
  position: relative;
  width: 100%;
  height: 260px;
}

canvas {
  width: 100% !important;
  height: 100% !important;
}

/* Spotlight badge */
.nl-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  background: rgba(255, 127, 0, 0.12);
  border-radius: 999px;
  padding: 4px 10px;
  border: 1px solid rgba(255, 127, 0, 0.4);
  color: #fed7aa;
}

.nl-dot {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: var(--accent);
}

/* Details */
#details {
  border-radius: 18px;
  background: rgba(15, 23, 42, 0.98);
  border: 1px solid #1f2937;
}

#details h3 {
  margin: 0 0 8px;
  font-size: 16px;
  font-weight: 600;
}

#detailsContent ul {
  margin: 6px 0 0;
  padding-left: 18px;
  font-size: 13px;
}

#detailsContent li {
  margin-bottom: 2px;
}

/* Dynamic Island pill */
#liveActivity {
  position: fixed;
  top: 10px;
  left: 50%;
  transform: translateX(-50%);
  background: #020617;
  color: #f5f5f5;
  padding: 8px 16px;
  border-radius: 999px;
  font-size: 13px;
  border: 1px solid var(--accent);
  z-index: 1000;
  max-width: 80%;
  text-overflow: ellipsis;
  white-space: nowrap;
  overflow: hidden;
}

/* Bottom tabs */
#bottomTabs {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  background: rgba(15, 23, 42, 0.96);
  backdrop-filter: blur(18px);
  border-top: 1px solid #1f2937;
  display: flex;
  justify-content: space-around;
  padding: 8px 0 14px;
  z-index: 999;
}

#bottomTabs button {
  background: none;
  border: none;
  color: #e5e7eb;
  font-size: 13px;
  padding: 6px 10px;
}

#bottomTabs button.active {
  color: var(--accent);
  font-weight: 600;
}

button:active {
  transform: scale(0.97);
}

/* Next match button */
#nextMatchBtn {
  margin-top: 10px;
  padding: 10px 14px;
  border-radius: 12px;
  background: var(--accent);
  border: none;
  color: #fff;
  font-weight: 600;
  font-size: 13px;
}

/* Follow chart styling */
#followChartCard {
  border-left: 3px solid var(--accent);
}

#followChartCard h2 {
  color: var(--accent);
}

/* Animations */
.theme-transition {
  transition: all 0.35s ease;
}

.fade-slide {
  animation: fadeSlide 0.35s ease;
}

@keyframes fadeSlide {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Mobile bottom sheet */
@media (max-width: 820px) {
  main {
    padding: 10px 12px 80px;
  }

  .card {
    border-radius: 20px;
  }

  .chart-container {
    height: 230px;
  }

  #details {
    position: fixed;
    bottom: 52px;
    left: 0;
    width: 100%;
    max-height: 55%;
    overflow-y: auto;
    border-radius: 22px 22px 0 0;
    padding: 18px 20px;
    box-shadow: 0 -18px 40px rgba(0, 0, 0, 0.9);
    animation: slideUp 0.25s ease-out;
    z-index: 950;
  }

  @keyframes slideUp {
    from { transform: translateY(100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
